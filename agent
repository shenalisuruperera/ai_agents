#!/data/data/com.termux/files/usr/bin/bash

BASE="$HOME/ai_agents"

case "$1" in
  add)
    cd "$BASE"
    . .venv/bin/activate
    python reminder/ai_reminder_agent.py
    ;;

  list)
    python "$BASE/reminder/list_reminders.py"
    ;;

  check)
    "$BASE/run_reminder_check.sh"
    ;;

  logs)
    cat "$BASE/logs/scheduler.log"
    ;;

  work)
    cd "$BASE"
    . .venv/bin/activate
    python work/work_job_agent.py
    ;;

  *)
    echo "Usage:"
    echo "  agent add     - add reminder with AI"
    echo "  agent list    - list reminders"
    echo "  agent check   - check due reminders now"
    echo "  agent logs    - show scheduler logs"
    echo "  agent work    - manually add work job"
    ;;
esac
